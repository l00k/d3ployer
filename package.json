{
    "name": "d3ployer",
    "version": "0.0.7",
    "license": "MIT",
    "type": "module",
    "bin": {
        "dpl": "dist/bin.js"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "build:watch": "tsc -p tsconfig.build.json --watch",
        "test": "mocha --import=tsx",
        "test:inspect": "mocha --import=tsx --inspect-brk",
        "coverage": "c8 mocha --import=tsx",
        "prepare": "husky"
    },
    "dependencies": {
        "@inquirer/confirm": "^6.0.10",
        "chalk": "^5.6.2",
        "commander": "^14.0.3",
        "listr2": "^10.2.1",
        "lodash-es": "^4.17.23",
        "ssh2-promise": "^1.0.3"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.3",
        "@stylistic/eslint-plugin": "^2.13.0",
        "@tsconfig/node24": "^24.0.4",
        "@types/chai": "^5.2.3",
        "@types/chai-as-promised": "^8.0.2",
        "@types/lodash-es": "^4.17.12",
        "@types/mocha": "^10.0.10",
        "@types/node": "^24.10.13",
        "c8": "^10.1.3",
        "chai": "^6.2.2",
        "chai-as-promised": "^8.0.2",
        "eslint": "^8.57.1",
        "eslint-plugin-import": "^2.32.0",
        "husky": "^9.1.7",
        "lint-staged": "^15.5.2",
        "mocha": "^11.3.0",
        "patch-package": "^8.0.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.0"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "eslint --fix",
            "git add"
        ]
    }
}
